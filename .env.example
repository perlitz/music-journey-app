# Copy this file to ".env" and fill in the values.

# --- Spotify ---
# Client ID is NOT a secret (PKCE flow in the browser).
VITE_SPOTIFY_CLIENT_ID=your_client_id_here
# Must match EXACTLY what you registered in the Spotify dashboard.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/
# Client SECRET — used only by the build scripts (scripts/resolve.mjs) to get a
# Client-Credentials token for searching Spotify. Server-side only, never VITE_.
# Spotify dashboard → your app → Settings → View client secret.
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# --- ElevenLabs (build scripts only — never prefixed with VITE_) ---
# Secret. Used by scripts/prerender.mjs to generate narration audio.
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Optional overrides:
# ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb    # a voice ID (not a name)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2  # eleven_v3 is often UI-only / not API-usable
